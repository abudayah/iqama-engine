# ─────────────────────────────────────────────────────────────────────────────
# iqama-engine — Environment Variables
# Copy this file to .env and fill in the required values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Masjid Location ──────────────────────────────────────────────────────────

# Latitude of the masjid used for astronomical prayer-time calculation.
# Default: 49.2514 (Surrey, BC)
MASJID_LATITUDE=49.2514

# Longitude of the masjid used for astronomical prayer-time calculation.
# Default: -122.7740 (Surrey, BC)
MASJID_LONGITUDE=-122.7740

# IANA timezone string for the masjid's local time.
# Used for DST detection and HH:mm formatting.
# Default: America/Vancouver
MASJID_TIMEZONE=America/Vancouver

# ── Database (MySQL) ──────────────────────────────────────────────────────────

# MySQL connection string used by Prisma for admin override storage.
# Example: mysql://user:password@localhost:3306/iqama
DATABASE_URL=

# ── Admin API Security ────────────────────────────────────────────────────────

# API key for authenticating admin endpoints (override management).
# Generate a secure random string (e.g., using `openssl rand -hex 32`).
# Required for all /api/v1/admin/* endpoints.
ADMIN_API_KEY=
