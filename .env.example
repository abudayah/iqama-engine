# ─────────────────────────────────────────────────────────────────────────────
# iqama-engine — Environment Variables
# Copy this file to .env and fill in the required values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Masjid Location ──────────────────────────────────────────────────────────

# Latitude of the masjid used for astronomical prayer-time calculation.
# Default: Masjid al-Hidayah, 2626 Kingsway Ave, Port Coquitlam, BC
MASJID_LATITUDE=49.2652047

# Longitude of the masjid used for astronomical prayer-time calculation.
# Default: Masjid al-Hidayah, 2626 Kingsway Ave, Port Coquitlam, BC
MASJID_LONGITUDE=-122.7878735

# IANA timezone string for the masjid's local time.
# Used for DST detection and HH:mm formatting.
# Default: America/Vancouver
MASJID_TIMEZONE=America/Vancouver

# ── Database (SQLite) ──────────────────────────────────────────────────────────

# SQLite database file path
# Example: file:./prisma/db.sqlite
DATABASE_URL=file:./prisma/db.sqlite

# ── Admin Security ────────────────────────────────────────────────────────────

# Password for authenticating admin endpoints (override management).
# Required for all /api/v1/admin/* endpoints.
ADMIN_PASSWORD=

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins for the browser CORS policy.
# Use '*' to allow all origins (dev only). Leave empty to disable CORS headers.
# Example: CORS_ORIGIN=http://localhost:5173,https://prayers.example.com
CORS_ORIGIN=
